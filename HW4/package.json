{
  "name": "drop-lottery",
  "version": "1.0.0",
  "private": true,
  "description": "Децентрализованная лотерея на Ethereum",
  "scripts": {
    "contracts:install": "cd contracts && npm install",
    "app:install": "cd app && npm install",
    "install:all": "npm run contracts:install && npm run app:install",
    "contracts:compile": "cd contracts && npx hardhat compile",
    "contracts:test": "cd contracts && npm test",
    "contracts:node": "cd contracts && npx hardhat node",
    "contracts:deploy:local": "cd contracts && npm run deploy:local",
    "contracts:deploy:sepolia": "cd contracts && npm run deploy:sepolia",
    "contracts:upkeep": "cd contracts && npm run upkeep",
    "app:dev": "cd app && npm run dev",
    "app:build": "cd app && npm run build"
  }
}
